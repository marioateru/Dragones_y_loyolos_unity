			"backgroundColor": "#ffec99",
			"fillStyle": "solid",
			"strokeWidth": 4,
			"strokeStyle": "solid",
			"roughness": 0,
			"opacity": 100,
			"groupIds": [],
			"frameId": null,
			"index": "b30O",
			"roundness": null,
			"seed": 944496035,
			"version": 705,
			"versionNonce": 996423197,
